{
  "name": "@fancyliu/aiforge",
  "version": "2.0.4",
  "description": "AI rules installer - sync AI tool configurations from a knowledge repository",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "aiforge": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint . && prettier --check .",
    "lint:src": "eslint src/ tests/ && prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint . --fix && prettier --write .",
    "release:check": "npm run lint && npm test && npm run build && npm pack --dry-run",
    "prepack": "node scripts/prepare-npm-readme.mjs --apply",
    "postpack": "node scripts/prepare-npm-readme.mjs --restore",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh.md",
    "docs/*.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "ai",
    "copilot",
    "claude",
    "cursor",
    "vscode",
    "agents",
    "skills",
    "mcp",
    "cli",
    "installer",
    "configuration"
  ],
  "author": "Wshoto",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^8.2.0",
    "simple-git": "~3.32"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
